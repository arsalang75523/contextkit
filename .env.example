# ContextKit
CONTEXTKIT_API_KEY=replace_with_contextkit_api_key
CONTEXTKIT_ADMIN_TOKEN=replace_me_for_key_issuance
CONTEXTKIT_INTERNAL_TOKEN=replace_me_for_bankr_x402_forwarder
CONTEXTKIT_WEBHOOK_SECRET=whsec_replace_me
CONTEXTKIT_BASE_URL=http://localhost:3000
CONTEXTKIT_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_BANKR_X402_BASE_URL=https://x402.bankr.bot/your-wallet
DATABASE_URL=postgres://contextkit:contextkit_password@localhost:5432/contextkit

# Password reset email delivery (Resend)
RESEND_API_KEY=re_replace_me
CONTEXTKIT_EMAIL_FROM=ContextKit <security@your-domain.com>

# Bankr LLM Gateway
BANKR_LLM_KEY=bk_replace_me
BANKR_LLM_BASE_URL=https://llm.bankr.bot/v1
BANKR_LLM_MODEL=claude-sonnet-4.5

# x402 settlement / facilitator settings
X402_PAY_TO=0x0000000000000000000000000000000000000000
X402_NETWORK=base
X402_FACILITATOR_URL=https://facilitator.x402.org
CREDIT_BASE_RPC_URL=https://mainnet.base.org
CREDIT_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Optional durable storage bindings when deployed on Cloudflare
CONTEXTKIT_KV_NAMESPACE=contextkit
CONTEXTKIT_FILES_BUCKET=contextkit-audit
