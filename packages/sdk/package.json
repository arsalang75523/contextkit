{
  "name": "@basedchef/contextkit",
  "version": "0.1.1",
  "description": "TypeScript SDK for ContextKit, a Bankr-hosted x402 context API for AI agents, memory compression, handoffs, profiles, and webhooks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "author": "basedchef",
  "homepage": "https://91.107.248.223.sslip.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arsalang75523/contextkit.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/arsalang75523/contextkit/issues"
  },
  "keywords": [
    "contextkit",
    "ai",
    "ai-agents",
    "agent-memory",
    "context-compression",
    "context-engineering",
    "summarization",
    "handoff",
    "webhooks",
    "x402",
    "bankr",
    "typescript-sdk"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
