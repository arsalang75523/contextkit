{
  "network": "base",
  "currency": "USDC",
  "services": {
    "contextkit-summarize": {
      "description": "Summarize long AI conversations into concise reusable context for autonomous agents.",
      "price": "0.05",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "context", "summarization", "bankr", "token-optimization"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "messages": {
              "type": "array",
              "description": "Conversation messages to summarize.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string", "description": "Message role: user, assistant, system, or tool." },
                  "content": { "type": "string", "description": "Message content." }
                },
                "required": ["role", "content"]
              }
            },
            "mode": {
              "type": "string",
              "description": "Summary mode: micro, compact, extended, or debug. Defaults to compact.",
              "enum": ["micro", "compact", "extended", "debug"]
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads. Use /api/context/upload first."
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "description": "Selected summary mode." },
            "summary": { "type": "string", "description": "Optimized context summary." },
            "tokenReductionEstimate": { "type": "number", "description": "Actual compact-summary token reduction percentage." },
            "micro": { "type": "string", "description": "Maximum-compression summary." },
            "compact": { "type": "string", "description": "Default continuation summary." },
            "extended": { "type": "string", "description": "Human-readable compressed summary." },
            "state": { "type": "object", "description": "Goal, status, blockers, and next steps. Omitted in micro mode." },
            "metrics": {
              "type": "object",
              "description": "Micro metrics include inputTokens, microTokens, reductionPercent only. Compact/extended/debug include full token and latency metrics."
            }
          }
        }
      }
    },
    "contextkit-compress": {
      "description": "Compress agent conversation context into compact structured memory.",
      "price": "0.03",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "context-compression", "memory", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "messages": {
              "type": "array",
              "description": "Conversation messages to compress.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads. Use /api/context/upload first."
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "compressedContext": { "type": "string" },
            "estimatedSavings": { "type": "string" }
          }
        }
      }
    },
    "contextkit-handoff": {
      "description": "Generate structured agent-to-agent handoff payloads.",
      "price": "0.03",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["multi-agent", "handoff", "workflow", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "messages": {
              "type": "array",
              "description": "Conversation messages to convert into a handoff.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads. Use /api/context/upload first."
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "goal": { "type": "string" },
            "importantFacts": { "type": "array", "items": { "type": "string" } },
            "constraints": { "type": "array", "items": { "type": "string" } },
            "recommendedNextActions": { "type": "array", "items": { "type": "string" } },
            "tone": { "type": "string" },
            "userIntent": { "type": "string" }
          }
        }
      }
    },
    "contextkit-profile": {
      "description": "Extract reusable user profile or memory enrichment for autonomous AI agents.",
      "price": "0.04",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["profile", "memory", "personalization", "ai-agents"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "messages": {
              "type": "array",
              "description": "Conversation messages to extract profile data from.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads. Use /api/context/upload first."
            },
            "mode": {
              "type": "string",
              "description": "Profile mode: extract-profile or memory-enrichment. Defaults to extract-profile.",
              "enum": ["extract-profile", "memory-enrichment"]
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "interests": { "type": "array", "items": { "type": "string" } },
            "riskTolerance": { "type": "string" },
            "communicationStyle": { "type": "string" },
            "preferences": { "type": "array", "items": { "type": "string" } },
            "importantContext": { "type": "array", "items": { "type": "string" } },
            "stableMemories": { "type": "array", "items": { "type": "string" } },
            "evolvingMemories": { "type": "array", "items": { "type": "string" } },
            "deprecatedMemories": { "type": "array", "items": { "type": "string" } },
            "memoryImportance": { "type": "number" },
            "confidence": { "type": "number" }
          }
        }
      }
    }
  }
}
