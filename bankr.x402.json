{
  "network": "base",
  "currency": "USDC",
  "services": {
    "contextkit-core": {
      "description": "Run core ContextKit operations with modes: summarize, compress-context, handoff, extract-profile, or memory-enrichment.",
      "price": "0.03",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "context", "summarization", "compression", "handoff", "profile", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "Core operation to run. Defaults to summarize.",
              "enum": ["summarize", "compress-context", "handoff", "extract-profile", "memory-enrichment"]
            },
            "messages": {
              "type": "array",
              "description": "Conversation messages for the selected operation.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string", "description": "Message role: user, assistant, system, or tool." },
                  "content": { "type": "string", "description": "Message content." }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads. Use /api/context/upload first."
            },
            "mode": {
              "type": "string",
              "description": "Summarize mode or profile mode. Summarize defaults to compact.",
              "enum": ["micro", "compact", "extended", "debug", "extract-profile", "memory-enrichment"]
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "mode": { "type": "string" },
            "micro": { "type": "string" },
            "compact": { "type": "string" },
            "extended": { "type": "string" },
            "state": { "type": "object", "description": "Structured state for summarize, compress, and handoff modes." },
            "compressedContext": { "type": "string" },
            "project": { "type": "object" },
            "profile": { "type": "object" },
            "stableMemories": { "type": "array", "items": { "type": "string" } },
            "metrics": { "type": "object" }
          }
        }
      }
    },
    "contextkit-experience-write": {
      "description": "Compile completed Bankr-adjacent work into tested SKILL.md drafts or publish verified installable skills.",
      "price": "0.01",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "verified-skills", "skill-md", "marketplace", "publish", "mcp", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "description": "Use skill-compile for completed work or skill-publish for an approved verified draft. Legacy experience modes remain accepted.",
              "enum": ["skill-compile", "skill-publish", "experience-consider", "experience-save", "experience-publish", "consider", "save", "publish"]
            },
            "experience": {
              "type": "object",
              "description": "Legacy input record. New skill drafts are compiled from messages and validated before publishing.",
              "properties": {
                "experienceId": { "type": "string" },
                "goal": { "type": "string", "description": "Original task or objective." },
                "context": { "type": "string", "description": "Relevant execution context." },
                "actionTaken": { "type": "string", "description": "What the agent tried or changed." },
                "outcome": { "type": "string", "description": "Result of the attempt." },
                "constraints": { "type": "array", "items": { "type": "string" } },
                "lesson": { "type": "string", "description": "Reusable lesson for future agents." },
                "title": { "type": "string", "description": "Marketplace title for publish mode." },
                "description": { "type": "string", "description": "Marketplace description for publish mode." },
                "priceUsd": { "type": "number", "description": "Suggested marketplace purchase price." },
                "tags": { "type": "array", "items": { "type": "string" } },
                "visibility": { "type": "string", "enum": ["private", "public"] }
              }
            },
            "messages": {
              "type": "array",
              "description": "Optional source messages to convert into an experience record.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads."
            },
            "minConfidence": {
              "type": "number",
              "description": "Minimum confidence required for experience-consider to save a private draft."
            },
            "autoSave": {
              "type": "boolean",
              "description": "Whether skill-compile should save a private SKILL.md draft when completed reusable work passes evidence checks."
            },
            "skillId": {
              "type": "string",
              "description": "Private verified skill ID for skill-publish mode. Explicit user approval is required before calling publish."
            },
            "publishToken": {
              "type": "string",
              "description": "Capability returned with a Bankr-hosted private draft. Required with skillId when publishing through the shared hosted endpoint."
            },
            "userApproved": {
              "type": "boolean",
              "enum": [true],
              "description": "Required in skill-publish mode. Confirms the user explicitly approved public listing."
            },
            "priceUsd": {
              "type": "number",
              "enum": [0.05],
              "description": "Fixed v1 marketplace price for a verified skill."
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "experience": { "type": "object", "description": "Private compiled draft or published verified skill record." },
            "publishToken": { "type": "string", "description": "Returned only for a new Bankr-hosted private draft; required to publish that draft." },
            "skill": { "type": "object", "description": "Compiled portable skill preview." },
            "validation": { "type": "object", "description": "Quality score, contract-test results, findings, and publish eligibility." },
            "shouldSave": { "type": "boolean" },
            "marketplace": { "type": "object", "description": "Present after successful public listing." }
          }
        }
      }
    },
    "contextkit-experience-search": {
      "description": "Search ContextKit Verified Skills by problem, ecosystem, tags, or compatible agent host.",
      "price": "0.01",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "verified-skill-search", "skill-md", "marketplace", "mcp", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query or current agent problem." },
            "tags": { "type": "array", "items": { "type": "string" }, "description": "Optional tags to filter by." },
            "ecosystems": { "type": "array", "items": { "type": "string" }, "description": "Filter by Bankr, x402, Base, MCP, wallet, DeFi, automation, LLM gateway, or agent infrastructure." },
            "compatibility": { "type": "array", "items": { "type": "string" }, "description": "Filter by Bankr, Claude Code, Codex, OpenClaw, Cursor, or another compatible host." },
            "limit": { "type": "integer", "description": "Maximum results to return." },
            "visibility": { "type": "string", "description": "private, public, or all.", "enum": ["private", "public", "all"] },
            "contextId": { "type": "string", "description": "Optional uploaded ContextKit context ID to search from." }
          },
          "required": ["query"]
        },
        "output": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "experienceId": { "type": "string" },
                  "skill": { "type": "object" },
                  "validation": { "type": "object" },
                  "listingId": { "type": "string" },
                  "title": { "type": "string" },
                  "lesson": { "type": "string" },
                  "score": { "type": "number" },
                  "priceUsd": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "contextkit-experience-buy": {
      "description": "Buy a verified installable SKILL.md bundle through Bankr x402.",
      "price": "0.05",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "verified-skill-marketplace", "buy", "skill-md", "mcp", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "listingId": { "type": "string", "description": "Marketplace listing ID." },
            "skillId": { "type": "string", "description": "Verified skill ID. Either skillId or listingId is accepted." },
            "buyerContext": { "type": "string", "description": "Optional current task context for matching." },
            "contextId": { "type": "string", "description": "Optional uploaded ContextKit context ID for buyer context." }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "experienceId": { "type": "string" },
            "skill": { "type": "object", "description": "Full verified skill record." },
            "installBundle": { "type": "object", "description": "SKILL.md plus versioned manifest and validation report." },
            "license": { "type": "object" }
          }
        }
      }
    }
  }
}
