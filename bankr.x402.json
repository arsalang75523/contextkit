                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              }
            }
          },
          "required": ["messages"]
        },
        "output": {
          "type": "object",
          "properties": {
            "compressedContext": { "type": "string" },
            "estimatedSavings": { "type": "string" }
          }
        }
      }
    },
