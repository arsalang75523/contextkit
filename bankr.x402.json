{
  "network": "base",
  "currency": "USDC",
  "services": {
    "contextkit-core": {
      "description": "Run core ContextKit operations with modes: summarize, compress-context, handoff, extract-profile, or memory-enrichment.",
      "price": "0.05",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "context", "summarization", "compression", "handoff", "profile", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "Core operation to run. Defaults to summarize.",
              "enum": ["summarize", "compress-context", "handoff", "extract-profile", "memory-enrichment"]
            },
            "messages": {
              "type": "array",
              "description": "Conversation messages for the selected operation.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string", "description": "Message role: user, assistant, system, or tool." },
                  "content": { "type": "string", "description": "Message content." }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads. Use /api/context/upload first."
            },
            "mode": {
              "type": "string",
              "description": "Summarize mode or profile mode. Summarize defaults to compact.",
              "enum": ["micro", "compact", "extended", "debug", "extract-profile", "memory-enrichment"]
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "mode": { "type": "string" },
            "micro": { "type": "string" },
            "compact": { "type": "string" },
            "extended": { "type": "string" },
            "state": { "type": "object", "description": "Structured state for summarize, compress, and handoff modes." },
            "compressedContext": { "type": "string" },
            "project": { "type": "object" },
            "profile": { "type": "object" },
            "stableMemories": { "type": "array", "items": { "type": "string" } },
            "metrics": { "type": "object" }
          }
        }
      }
    },
    "contextkit-experience-write": {
      "description": "MCP V2 experience write endpoint: save private experience records or publish marketplace listings.",
      "price": "0.03",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "experience", "memory", "marketplace", "publish", "mcp", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "description": "Write operation. Defaults to experience-save.",
              "enum": ["experience-save", "experience-publish", "save", "publish"]
            },
            "experience": {
              "type": "object",
              "description": "Experience record or marketplace listing payload.",
              "properties": {
                "experienceId": { "type": "string" },
                "goal": { "type": "string", "description": "Original task or objective." },
                "context": { "type": "string", "description": "Relevant execution context." },
                "actionTaken": { "type": "string", "description": "What the agent tried or changed." },
                "outcome": { "type": "string", "description": "Result of the attempt." },
                "constraints": { "type": "array", "items": { "type": "string" } },
                "lesson": { "type": "string", "description": "Reusable lesson for future agents." },
                "title": { "type": "string", "description": "Marketplace title for publish mode." },
                "description": { "type": "string", "description": "Marketplace description for publish mode." },
                "priceUsd": { "type": "number", "description": "Suggested marketplace purchase price." },
                "tags": { "type": "array", "items": { "type": "string" } },
                "visibility": { "type": "string", "enum": ["private", "public"] }
              }
            },
            "messages": {
              "type": "array",
              "description": "Optional source messages to convert into an experience record.",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              }
            },
            "contextId": {
              "type": "string",
              "description": "Optional uploaded ContextKit context ID for large payloads."
            }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "experienceId": { "type": "string" },
            "listingId": { "type": "string" },
            "status": { "type": "string" },
            "visibility": { "type": "string" },
            "qualityScore": { "type": "number" },
            "reviewStatus": { "type": "string" },
            "publishQuotaRemaining": { "type": "integer" }
          }
        }
      }
    },
    "contextkit-experience-search": {
      "description": "MCP V2 experience search endpoint for finding reusable agent lessons and marketplace records.",
      "price": "0.01",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "experience-search", "memory", "marketplace", "mcp", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query or current agent problem." },
            "tags": { "type": "array", "items": { "type": "string" }, "description": "Optional tags to filter by." },
            "limit": { "type": "integer", "description": "Maximum results to return." },
            "visibility": { "type": "string", "description": "private, public, or all.", "enum": ["private", "public", "all"] },
            "contextId": { "type": "string", "description": "Optional uploaded ContextKit context ID to search from." }
          },
          "required": ["query"]
        },
        "output": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "experienceId": { "type": "string" },
                  "listingId": { "type": "string" },
                  "title": { "type": "string" },
                  "lesson": { "type": "string" },
                  "score": { "type": "number" },
                  "priceUsd": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "contextkit-experience-buy": {
      "description": "MCP V2 experience buy endpoint for purchasing published agent experience records through Bankr x402.",
      "price": "0.03",
      "methods": ["POST"],
      "category": "ai-infrastructure",
      "tags": ["ai-agents", "experience-marketplace", "buy", "memory", "mcp", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "listingId": { "type": "string", "description": "Marketplace listing ID." },
            "buyerContext": { "type": "string", "description": "Optional current task context for matching." },
            "contextId": { "type": "string", "description": "Optional uploaded ContextKit context ID for buyer context." }
          },
          "required": ["listingId"]
        },
        "output": {
          "type": "object",
          "properties": {
            "experienceId": { "type": "string" },
            "goal": { "type": "string" },
            "lesson": { "type": "string" },
            "constraints": { "type": "array", "items": { "type": "string" } },
            "recommendedUse": { "type": "string" },
            "license": { "type": "string" }
          }
        }
      }
    }
  }
}
